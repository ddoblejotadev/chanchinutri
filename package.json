  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "test": "jest",
    "test:watch": "jest --watch",
    "release:build": "node scripts/build-android-release.js",
    "verify-release": "node scripts/verify-release-artifact.js",
    "gate:release": "npm run quality:base && npm run verify-release",
    "build:verify": "expo export --platform android --output-dir dist-build-check",
