    "@types/lodash": "^4.17.24",
    "expo": "~54.0.0",
    "expo-build-properties": "~1.0.10",
    "expo-print": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "lodash": "^4.17.23",
    "react": "^19.1.0",
    "react-native": "^0.81.5",
    "react-native-chart-kit": "^6.12.0",
    "react-native-safe-area-context": "~5.6.0",
